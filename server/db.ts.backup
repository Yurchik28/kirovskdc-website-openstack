export async function getUserByEmail(email: string) {
  const [rows] = await pool.execute(
    "SELECT id, email, password_hash, role, accountBalance FROM users WHERE email = ?",
    [email]
  );
  return (rows as any[])[0];
}

export async function getUserBillingHistory(userId: number, limit: number) {
  const [rows] = await pool.execute(
    "SELECT * FROM billing_records WHERE userId = ? ORDER BY createdAt DESC LIMIT ?",
    [userId, limit]
  );
  return rows;
}

export async function getUserBillingStats(userId: number) {
  const [rows] = await pool.execute(
    "SELECT SUM(amount) as totalSpent, SUM(CASE WHEN MONTH(createdAt) = MONTH(NOW()) THEN amount ELSE 0 END) as thisMonth FROM billing_records WHERE userId = ?",
    [userId]
  );
  return (rows as any[])[0] || { totalSpent: 0, thisMonth: 0 };
}

// Функции для аутентификации и OAuth
export async function getUserByOpenId(openId: string) {
  const [rows] = await pool.execute(
    "SELECT id, openId, email, password_hash, role, name, accountBalance FROM users WHERE openId = ?",
    [openId]
  );
  return (rows as any[])[0];
}

export async function getUserById(id: number) {
  const [rows] = await pool.execute(
    "SELECT id, openId, email, password_hash, role, name, accountBalance FROM users WHERE id = ?",
    [id]
  );
  return (rows as any[])[0];
}

export async function upsertUser(userData: any) {
  const existing = await getUserByOpenId(userData.openId);
  if (existing) {
    await pool.execute(
      "UPDATE users SET name = ?, email = ?, loginMethod = ?, lastSignedIn = NOW() WHERE openId = ?",
      [userData.name || null, userData.email || null, userData.loginMethod || null, userData.openId]
    );
    return getUserByOpenId(userData.openId);
  } else {
    const [result] = await pool.execute(
      "INSERT INTO users (openId, name, email, loginMethod, role, accountBalance) VALUES (?, ?, ?, ?, 'user', 1000)",
      [userData.openId, userData.name || null, userData.email || null, userData.loginMethod || null]
    );
    return getUserById((result as any).insertId);
  }
}

