export async function getAllCloudServers() {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(cloudServers).where(eq(cloudServers.isActive, true));
}

  const [rows] = await pool.execute(
    "SELECT id, email, password, role, name FROM users WHERE email = ?",
    [email]
  );
  return (rows as any[])[0];
}

export async function getCloudServerById(id: number) {
  const db = await getDb();
  if (!db) return undefined;
  const result = await db.select().from(cloudServers).where(eq(cloudServers.id, id)).limit(1);
  return result.length > 0 ? result[0] : undefined;
}

  const [rows] = await pool.execute(
    "SELECT id, email, password, role, name FROM users WHERE email = ?",
    [email]
  );
  return (rows as any[])[0];
}

export async function getCloudServerBySlug(slug: string) {
  const db = await getDb();
  if (!db) return undefined;
  const result = await db.select().from(cloudServers).where(eq(cloudServers.slug, slug)).limit(1);
  return result.length > 0 ? result[0] : undefined;
}

  const [rows] = await pool.execute(
    "SELECT id, email, password, role, name FROM users WHERE email = ?",
