  return (rows as any[])[0];
}

export async function filterCloudServers(filters: {
  minCpu?: number;
  maxCpu?: number;
  minRam?: number;
  maxRam?: number;
  minPrice?: number;
  maxPrice?: number;
  category?: string;
  storageType?: string;
}) {
  const db = await getDb();
  if (!db) return [];

  let conditions = [eq(cloudServers.isActive, true)];

  if (filters.minCpu !== undefined) {
    conditions.push(gte(cloudServers.cpu, filters.minCpu));
  }
  if (filters.maxCpu !== undefined) {
    conditions.push(lte(cloudServers.cpu, filters.maxCpu));
  }
  if (filters.minRam !== undefined) {
    conditions.push(gte(cloudServers.ram, filters.minRam));
  }
  if (filters.maxRam !== undefined) {
    conditions.push(lte(cloudServers.ram, filters.maxRam));
  }
  if (filters.category) {
    conditions.push(eq(cloudServers.category, filters.category as any));
  }
  if (filters.storageType) {
    conditions.push(eq(cloudServers.storageType, filters.storageType as any));
  }

  return db.select().from(cloudServers).where(and(...conditions));
}

