export async function filterGPUs(filters: {
  minMemory?: number; maxMemory?: number; category?: string; model?: string;
}) {
  const db = await getDb();
  if (!db) return [];
  const conditions = [eq(gpus.isActive, true)];
  if (filters.minMemory !== undefined) conditions.push(gte(gpus.memory, filters.minMemory));
  if (filters.maxMemory !== undefined) conditions.push(lte(gpus.memory, filters.maxMemory));
  if (filters.category) conditions.push(eq(gpus.category, filters.category as any));
  if (filters.model) conditions.push(eq(gpus.model, filters.model));
  return db.select().from(gpus).where(and(...conditions));
