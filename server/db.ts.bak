// ─── BILLING RECORDS ─────────────────────────────────────────────────────────

export async function getUserBillingRecords(userId: number, limit = 100) {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(billingRecords)
    .where(eq(billingRecords.userId, userId))
    .orderBy(desc(billingRecords.createdAt))
    .limit(limit);
}

export async function getBillingRecordsByInstance(
  instanceType: "cloud" | "gpu",
  instanceId: number,
  limit = 50
) {
  const db = await getDb();
  if (!db) return [];
  const condition = instanceType === "cloud"
    ? eq(billingRecords.cloudInstanceId, instanceId)
    : eq(billingRecords.gpuInstanceId, instanceId);
  return db.select().from(billingRecords)
    .where(condition)
    .orderBy(desc(billingRecords.createdAt))
    .limit(limit);
}

export async function getUserBillingStats(userId: number) {
  const db = await getDb();
  if (!db) return { totalSpent: 0, thisMonth: 0, recordCount: 0 };

  const now = new Date();
  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

  const [allRecords, monthRecords] = await Promise.all([
    db.select().from(billingRecords).where(eq(billingRecords.userId, userId)),
    db.select().from(billingRecords).where(
      and(eq(billingRecords.userId, userId), gte(billingRecords.createdAt, monthStart))
    ),
  ]);

  const totalSpent = allRecords.reduce((sum, r) => sum + Number(r.amount), 0);
  const thisMonth = monthRecords.reduce((sum, r) => sum + Number(r.amount), 0);

  return {
    totalSpent: Math.round(totalSpent * 100) / 100,
    thisMonth: Math.round(thisMonth * 100) / 100,
    recordCount: allRecords.length,
  };
}

