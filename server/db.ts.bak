// ─── CLOUD INSTANCES ─────────────────────────────────────────────────────────

export async function getUserCloudInstances(userId: number) {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(cloudInstances)
    .where(and(eq(cloudInstances.userId, userId)))
    .orderBy(desc(cloudInstances.createdAt));
}

export async function getCloudInstanceById(id: number) {
  const db = await getDb();
  if (!db) return undefined;
  const result = await db.select().from(cloudInstances).where(eq(cloudInstances.id, id)).limit(1);
  return result.length > 0 ? result[0] : undefined;
}

export async function createCloudInstance(data: InsertCloudInstance) {
  const db = await getDb();
  if (!db) throw new Error("DB not available");
  const result = await db.insert(cloudInstances).values(data);
  return result;
}

export async function startCloudInstance(id: number, userId: number) {
  const db = await getDb();
  if (!db) throw new Error("DB not available");
  const now = new Date();
  await db.update(cloudInstances)
    .set({ status: "running", startedAt: now, billingStartedAt: now, lastBilledAt: now, stoppedAt: null })
    .where(and(eq(cloudInstances.id, id), eq(cloudInstances.userId, userId)));
}

export async function stopCloudInstance(id: number, userId: number) {
  const db = await getDb();
  if (!db) throw new Error("DB not available");
  const now = new Date();
  await db.update(cloudInstances)
    .set({ status: "stopped", stoppedAt: now, billingStartedAt: null })
    .where(and(eq(cloudInstances.id, id), eq(cloudInstances.userId, userId)));
}

export async function terminateCloudInstance(id: number, userId: number) {
  const db = await getDb();
  if (!db) throw new Error("DB not available");
  const now = new Date();
  await db.update(cloudInstances)
    .set({ status: "terminated", terminatedAt: now, billingStartedAt: null })
    .where(and(eq(cloudInstances.id, id), eq(cloudInstances.userId, userId)));
}

